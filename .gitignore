# Build output (regenerated by build.bat)
/build/

# Packaged game-only payload (regenerated by package.bat)
/dist/
*.obj
*.exp
*.lib
*.ilk
*.pdb

# Heavy reverse-engineering artifacts — kept locally, not for version control.
# See docs/reference/ for how/why they were produced (re/ = dump + Ghidra project).
/re/ghidra_proj/
/re/*_proj/
/re/scratch_dec/
/re/*.bin
/re/*.dll
/re/*.log

# Bulky external reference addon (kept locally for feature comparison only)
/research/reference/Bars/
aio_config.txt
aiohud_profiles/
pol_*.png

# Runtime / debug scratch written by the plugin + //aio probes (regenerated in-game)
aio_active.txt
*_debug.txt
aiohud_debug.log
aiohud_*.bin

# Design concept deliverables — heavy binaries kept locally (the folder README is tracked)
docs/design/concepts/*.html
docs/design/concepts/*.pdf

# Personal session handoff note (local only)
/RESUME.md

# --- Dev / AI tooling, notes & internal docs (not part of the shipped plugin) ---
/.claude/
CLAUDE.md
/scratchpad/
# `/docs/*` and not `/docs/` : git does not descend into an excluded DIRECTORY, so a `!` negation inside one is
# silently dead. Excluding the CONTENTS instead leaves the directory walkable and lets the two subtrees below be
# re-included. Everything else under docs/ stays local.
/docs/*
# Reverse-engineered ground truth : offsets, packet layouts, the Ghidra addresses to redo a pass after a client
# patch. Reproducing this costs hours of captures and static analysis -- it must not live on one machine only.
!/docs/game-data/
# Measured audit findings (what was wrong, how it was proven). Same argument: the proof is the expensive part.
!/docs/audits/
/research/
/re/
# loose dev notes / feature docs (the analyses/audits now live under /docs/, already ignored above)
/FOCUS.md
/design/README.md
/design/exports/DESIGN_BRIEF.md

# dev-only diagnostic probes (kept local, excluded from the public repo)
/src/plugin/aiohud_probes.cpp
/src/plugin/aiohud_probes.h

# local, untracked deploy target (personal Windower path)
deploy.local.bat

# personal editor workspace
/aiohud.code-workspace
